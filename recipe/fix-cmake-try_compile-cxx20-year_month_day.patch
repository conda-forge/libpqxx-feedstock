+# std::chrono::year_month_day requires C++20.
+# MSVC does not enable C++20 features by default, so we must explicitly
+# request CXX_STANDARD 20 here, or the try_compile will fail on MSVC
+# even when the compiler supports it (VS 2019 16.10+ / VS 2022).
 try_compile(
     PQXX_HAVE_YEAR_MONTH_DAY ${PROJECT_BINARY_DIR}
     SOURCES ${PROJECT_SOURCE_DIR}/config-tests/PQXX_HAVE_YEAR_MONTH_DAY.cxx
+    CXX_STANDARD 20
+    CXX_STANDARD_REQUIRED ON
 )
 try_compile(
     PQXX_HAVE_ZARGS ${PROJECT_BINARY_DIR}
